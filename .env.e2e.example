# Copy to .env.e2e (local only — never commit .env.e2e)
#
# Dedicated E2E stack (Postgres :5440, Redis :6389, app :3199).
# Host tools (prepare-db, Playwright, host-run app) use these localhost URLs.
# The Docker app service overrides DATABASE_URL / REDIS_URL to in-compose hostnames.
#
#   pnpm e2e:setup      # infra + migrate/seed + Docker app
#   pnpm test:e2e       # Playwright against http://localhost:3199
#   pnpm e2e:app:host   # optional: Nuxt on host instead of Docker app

E2E_MODE=true
E2E_PORT=3199
E2E_BASE_URL=http://localhost:3199

DATABASE_URL=postgresql://watts:password@localhost:5440/coach_e2e?connection_limit=5&pool_timeout=10&connect_timeout=10

# Dedicated E2E Redis (docker-compose.e2e.yml → host port 6389)
REDIS_URL=redis://:dragonfly@localhost:6389/0

NUXT_AUTH_SECRET=e2e-test-auth-secret-change-me-min-32-chars
NUXT_AUTH_ORIGIN=http://localhost:3199/api/auth
NUXT_PUBLIC_SITE_URL=http://localhost:3199/

E2E_TEST_USER_EMAIL=e2e-athlete@coachwatts.test
E2E_TEST_ADMIN_EMAIL=e2e-admin@coachwatts.test

# Seeded Official Mobile App stand-in (see e2e/seed.ts)
E2E_MOBILE_CLIENT_ID=e2e00000-0000-4000-8000-000000000001

# Reduce noise and side effects during tests
DISABLE_EMAILS=true
TOLGEE_API_ENABLED=false
NUXT_PUBLIC_SUBSCRIPTIONS_ENABLED=false
CHAT_TURN_RUNNER_ENABLED=false

# Must be empty — root .env AUTH_BYPASS_USER would skip login redirects
AUTH_BYPASS_USER=
AUTH_BYPASS_NAME=

# OAuth keys are not required for E2E login/token APIs, but NextAuth still expects placeholders.
GOOGLE_CLIENT_ID=e2e-placeholder
GOOGLE_CLIENT_SECRET=e2e-placeholder
STRAVA_CLIENT_ID=e2e-placeholder
STRAVA_CLIENT_SECRET=e2e-placeholder
INTERVALS_CLIENT_ID=e2e-placeholder
INTERVALS_CLIENT_SECRET=e2e-placeholder
