  sourceType          String
  metric              String
  period              Int
  title               String
  description         String
  priority            String
  generatedAt         DateTime  @default(now())
  completedAt         DateTime?
  isPinned            Boolean   @default(false)
  status              String    @default("ACTIVE")
  llmUsageId          String?
  history             Json?
  implementationGuide Json?
  category            String?
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, sourceType, metric])
  @@index([generatedAt])
  @@index([status])
  @@index([isPinned])
}

model DailyCheckin {
  id            String   @id @default(uuid())
  userId        String
  date          DateTime @db.Date
  questions     Json
  status        String   @default("PENDING")
  modelVersion  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  llmUsageId    String?
  feedback      String?
  feedbackText  String?
  userNotes     String?
  openingRemark String?
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId, date])
}

model ChatRoom {
  id            String            @id @default(uuid())
  name          String?
  avatar        String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  deletedAt     DateTime?
  lastMessageAt DateTime?         @default(now())
  metadata      Json?
  messages      ChatMessage[]
  turns         ChatTurn[]
  users         ChatParticipant[]
  bugReports    BugReport[]
  memories      UserMemory[]

  @@index([lastMessageAt])
}

model UserMemory {
  id              String             @id @default(uuid())
  userId          String
  scope           UserMemoryScope
  roomId          String?
  category        UserMemoryCategory
  content         String
  normalizedKey   String
  confidence      Float              @default(0.5)
  source          UserMemorySource
  status          UserMemoryStatus   @default(ACTIVE)
  pinned          Boolean            @default(false)
  sensitive       Boolean            @default(false)
  lastConfirmedAt DateTime?
  lastUsedAt      DateTime?
  metadata        Json?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  user            User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  room            ChatRoom?          @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([userId, scope, status])
  @@index([roomId, status])
  @@index([userId, normalizedKey, status])
}

model ChatParticipant {
  id       String    @id @default(uuid())
  userId   String
  roomId   String
  lastSeen DateTime?
  room     ChatRoom  @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, roomId])
}

model ChatMessage {
  id        String   @id @default(uuid())
  content   String
  roomId    String
  turnId    String?
  senderId  String
  files     Json?
  replyToId String?
  seen      Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  metadata  Json?
  room      ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  turn      ChatTurn? @relation(fields: [turnId], references: [id], onDelete: SetNull)

  @@index([roomId, createdAt])
  @@index([turnId])
}

model ChatTurn {
  id                String                  @id @default(uuid())
  roomId            String
  userId            String
  userMessageId     String
  assistantMessageId String?
  status            String
  lineageId         String
  retryOfTurnId     String?
  runId             String?
  startedAt         DateTime?
  finishedAt        DateTime?
  failureReason     String?
  lastHeartbeatAt   DateTime?
  providerRequestId String?
  metadata          Json?
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
  room              ChatRoom                @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user              User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages          ChatMessage[]
  llmUsage          LlmUsage[]
  events            ChatTurnEvent[]
  toolExecutions    ChatTurnToolExecution[]

  @@index([roomId, createdAt])
  @@index([userId, createdAt])
  @@index([status, lastHeartbeatAt])
  @@index([lineageId, createdAt])
}

model ChatTurnEvent {
  id        String   @id @default(uuid())
  turnId     String
  type      String
  data      Json?
  createdAt DateTime @default(now())
  turn      ChatTurn @relation(fields: [turnId], references: [id], onDelete: Cascade)

  @@index([turnId, createdAt])
  @@index([type, createdAt])
}

model ChatTurnToolExecution {
  id             String   @id @default(uuid())
  turnId         String
  lineageId      String
  toolCallId     String
  toolName       String
  argsHash       String
  idempotencyKey String
  status         String
  result         Json?
  error          String?
  metadata       Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  turn           ChatTurn @relation(fields: [turnId], references: [id], onDelete: Cascade)

  @@unique([turnId, toolCallId])
  @@index([lineageId, toolName, argsHash, status])
  @@index([turnId, status])
  @@index([idempotencyKey])
}

model SyncQueue {
  id          String    @id @default(uuid())
  userId      String
  entityType  String
  entityId    String
  operation   String
  structureRevision Int?
  payload     Json
  status      String    @default("PENDING")
  attempts    Int       @default(0)
  lastAttempt DateTime?
  error       String?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([status, createdAt])
  @@index([entityType, entityId, structureRevision])
}

model QuotaDenial {
  id        String           @id @default(uuid())
  userId    String
  operation String
  tier      SubscriptionTier
  limit     Int
  used      Int
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([operation, tier, createdAt])
  @@index([createdAt])
}

model LlmUsage {
  id               String   @id @default(uuid())
  userId           String?
  turnId           String?
  provider         String
  model            String
  modelType        String?
  operation        String
  entityType       String?
  entityId         String?
  promptTokens     Int?
  completionTokens Int?
  cachedTokens     Int?     @default(0)
  reasoningTokens  Int?     @default(0)
  totalTokens      Int?
  estimatedCost    Float?
  durationMs       Int?
  ttft             Int?
  retryCount       Int      @default(0)
  success          Boolean
  errorType        String?
  errorMessage     String?
  promptPreview    String?
  responsePreview  String?
  createdAt        DateTime @default(now())
  promptFull       String?
  responseFull     String?
  feedback         String?
  feedbackText     String?
  counted          Boolean  @default(true)
  user             User?    @relation(fields: [userId], references: [id])
  turn             ChatTurn? @relation(fields: [turnId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([turnId])
  @@index([operation, createdAt])
  @@index([provider, model, createdAt])
  @@index([success, createdAt])
  @@index([createdAt])
}

model PlanAdherence {
  id               String         @id @default(uuid())
  workoutId        String         @unique
  plannedWorkoutId String
  overallScore     Int?
  intensityScore   Int?
  durationScore    Int?
  executionScore   Int?
  cadenceScore     Int?
  summary          String?
  deviations       Json?
  recommendations  Json?
  analysisStatus   String         @default("PENDING")
  analyzedAt       DateTime?
  modelVersion     String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  plannedWorkout   PlannedWorkout @relation(fields: [plannedWorkoutId], references: [id], onDelete: Cascade)
  workout          Workout        @relation(fields: [workoutId], references: [id], onDelete: Cascade)

  @@index([workoutId])
  @@index([plannedWorkoutId])
}

model SupportMessage {
  id                   String   @id @default(uuid())
  userId               String?
  email                String?
  name                 String?
  subject              String
  message              String
  autotaskTicketId     String?
  autotaskTicketNumber String?
  status               String   @default("OPEN")
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  user                 User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([email])
}

model WebhookLog {
  id          String    @id @default(uuid())
  provider    String
  eventType   String?
  payload     Json?
  headers     Json?
  query       Json?
  status      String    @default("PENDING")
  error       String?
  processedAt DateTime?
  createdAt   DateTime  @default(now())

  @@index([provider, eventType])
  @@index([createdAt])
  @@index([status])
}

model LlmAnalysisLevelSettings {
  id             String                 @id @default(uuid())
  level          String                 @unique // 'flash', 'pro', 'experimental'
  model          String                 @default("flash") // flash/pro family
  modelId        String                 @default("gemini-2.5-flash") // exact ID
  thinkingBudget Int                    @default(2000)
  thinkingLevel  String                 @default("low")
  maxSteps       Int                    @default(3)
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  overrides      LlmOperationOverride[]
}

model LlmOperationOverride {
  id                      String                   @id @default(uuid())
  analysisLevelSettingsId String
  operation               String
  model                   String?
  modelId                 String?
  thinkingBudget          Int?
  thinkingLevel           String?
  maxSteps                Int?
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  analysisLevelSettings   LlmAnalysisLevelSettings @relation(fields: [analysisLevelSettingsId], references: [id], onDelete: Cascade)

  @@unique([analysisLevelSettingsId, operation])
}

enum SubscriptionTier {
  FREE
  SUPPORTER
  PRO
}

enum TeamVisibility {
  COACHES_ONLY
  TEAMMATES
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  PAST_DUE
  UNPAID
  NONE
  CONTRIBUTOR
}

model BugReport {
  id          String             @id @default(uuid())
  userId      String
  chatRoomId  String?
  title       String
  description String
  context     Json?
  logs        String?
  status      BugStatus          @default(OPEN)
  priority    String?            @default("MEDIUM")
  metadata    Json?
  reactions   Json?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  chatRoom    ChatRoom?          @relation(fields: [chatRoomId], references: [id])
  comments    BugReportComment[]

  @@index([userId])
  @@index([chatRoomId])
  @@index([status])
}

model BugReportComment {
  id          String      @id @default(uuid())
  bugReportId String
  userId      String
  content     String
  isAdmin     Boolean     @default(false)
  type        CommentType @default(MESSAGE)
  acknowledgedAt DateTime?
  acknowledgedBy String?
  reactions   Json?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  bugReport   BugReport   @relation(fields: [bugReportId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([bugReportId])
  @@index([userId])
}

enum CommentType {
  NOTE
  MESSAGE
}

enum BugStatus {
  OPEN
  IN_PROGRESS
  NEED_MORE_INFO
  RESOLVED
  CLOSED
}

model UserNotification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String
  icon      String?
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([read])
  @@index([createdAt])
}

model AthleteJourneyEvent {
  id                 String               @id @default(uuid())
  userId             String
  timestamp          DateTime
  eventType          JourneyEventType
  category           JourneyEventCategory
  severity           Int                  @default(5)
  description        String?
  metabolicSnapshot  Json? // Stores E_bal, Fluid_debt, and Carb_rate at the time of the event
  suspectedTriggerId String?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  user               User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, timestamp])
  @@index([category])
}

enum JourneyEventType {
  SYMPTOM
  WELLNESS_CHECK
  RECOVERY_NOTE
}

enum JourneyEventCategory {
  GI_DISTRESS
  MUSCLE_PAIN
  FATIGUE
  SLEEP
  MOOD
  CRAMPING
  DIZZINESS
  HUNGER
}

enum EmailAudience {
  TRANSACTIONAL
  ENGAGEMENT
  MARKETING
}

enum EmailDeliveryStatus {
  QUEUED
  SENDING
  SENT
  DELIVERED
  OPENED
  CLICKED
  BOUNCED
  COMPLAINED
  UNSUBSCRIBED
  FAILED
  SUPPRESSED
}

enum EmailProvider {
  RESEND
}

enum EmailPreferenceChannel {
  EMAIL
}

enum UserMemoryScope {
  GLOBAL
  ROOM
}

enum UserMemoryCategory {
  PREFERENCE
  GOAL
  CONSTRAINT
  PROFILE
  COMMUNICATION
  TEMPORARY
}

enum UserMemorySource {
  AUTO
  USER_EXPLICIT
  MANUAL_UI
}

enum UserMemoryStatus {
  ACTIVE
  ARCHIVED
  DELETED
}

model EmailPreference {
  id                String                 @id @default(uuid())
  userId            String
  channel           EmailPreferenceChannel @default(EMAIL)
  onboarding        Boolean                @default(true)
  workoutAnalysis   Boolean                @default(true)
  thresholdUpdates  Boolean                @default(true)
  planUpdates       Boolean                @default(true)
  billing           Boolean                @default(true) // usually required/limited toggle UX
  productUpdates    Boolean                @default(true)
  retentionNudges   Boolean                @default(true)
  dailyCoach        Boolean                @default(true)
  dailyCoachTime    String?                @default("07:00") // 24h format HH:mm
  dailyCoachDays    String[]               @default(["MONDAY", "TUESDAY", "WEDNESDAY", "THURSDAY", "FRIDAY", "SATURDAY", "SUNDAY"])
  marketing         Boolean                @default(false)
  globalUnsubscribe Boolean                @default(false)
  consentUpdatedAt  DateTime               @default(now())
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  user              User                   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, channel])
  @@index([userId])
}

model EmailDelivery {
  id                String              @id @default(uuid())
  userId            String?
  templateKey       String // e.g. WORKOUT_ANALYSIS_READY_V1 (maps to code component)
  provider          EmailProvider       @default(RESEND)
  providerMessageId String?             @unique
  eventKey          String // e.g. WORKOUT_ANALYSIS_READY
  audience          EmailAudience
  status            EmailDeliveryStatus @default(QUEUED)
  toEmail           String
  subject           String
  htmlBody          String?             @db.Text
  textBody          String?             @db.Text
  fromEmail         String?
  replyToEmail      String?
  idempotencyKey    String?             @unique
  metadata          Json?
  errorCode         String?
  errorMessage      String?
  queuedAt          DateTime?
  sentAt            DateTime?
  deliveredAt       DateTime?
  openedAt          DateTime?
  clickedAt         DateTime?
  bouncedAt         DateTime?
  complainedAt      DateTime?
  unsubscribedAt    DateTime?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  user              User?               @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([eventKey, createdAt])
  @@index([status, createdAt])
  @@index([toEmail, createdAt])
}

model EmailSuppression {
  id        String   @id @default(uuid())
  email     String
  reason    String // UNSUBSCRIBE, BOUNCE, COMPLAINT, MANUAL
  source    String? // webhook/manual/system
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([email, reason, active])
  @@index([email])
}

model MetricHistory {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  type      String   // LTHR, FTP, MAX_HR, THRESHOLD_PACE, PEAK_POWER_5S, etc.
  value     Float
  oldValue  Float?
  
  date      DateTime @default(now())
  workoutId String?
  workout   Workout? @relation(fields: [workoutId], references: [id], onDelete: SetNull)
  
  source    String   @default("AUTOMATIC") // AUTOMATIC, MANUAL
  sportProfileName String?
  notes     String?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([type])
  @@index([date])
}

model BodyMeasurementEntry {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  recordedAt    DateTime
  metricKey     String
  displayName   String?
  value         Float
  unit          String
  source        String
  sourceRefType String?
  sourceRefId   String?
  notes         String?
  isDuplicate     Boolean          @default(false)
  isDeleted       Boolean          @default(false)
  customMetrics   Json?            @default("{}")
  createdAt       DateTime         @default(now())

  updatedAt     DateTime @updatedAt

  @@index([userId, metricKey, recordedAt(sort: Desc)])
  @@index([userId, recordedAt(sort: Desc)])
}

model PersonalBest {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  type      String   // RUN_1K, RUN_5K, POWER_5S, POWER_20M, CLIMB_MAX, etc.
  category  String   // RUN, CYCLE, SWIM, OTHER
  value     Float
  unit      String
  
  date      DateTime
  workoutId String?
  workout   Workout? @relation(fields: [workoutId], references: [id], onDelete: SetNull)
  
  notes     String?
  metadata  Json?    // Context stats: { avgHr: 160, avgCadence: 90, etc. }
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, type]) // Each user has one all-time best per type
  @@index([userId])
  @@index([category])
}

enum TeamRole {
  OWNER
  ADMIN
  COACH
  ATHLETE
}

model Team {
  id          String       @id @default(uuid())
  name        String
  slug        String       @unique
  description String?
  ownerId     String
  owner       User         @relation("TeamOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members     TeamMember[]
  groups      AthleteGroup[]
  invites     TeamInvite[]
  trainingPlans TrainingPlan[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([ownerId])
}

model TeamMember {
  id        String   @id @default(uuid())
  teamId    String
  userId    String
  role      TeamRole @default(ATHLETE)
  status    String   @default("ACTIVE")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@index([teamId])
  @@index([userId])
}

model AthleteGroup {
  id          String               @id @default(uuid())
  name        String
  description String?
  coachId     String
  teamId      String?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  coach       User                 @relation("CoachGroups", fields: [coachId], references: [id], onDelete: Cascade)
  team        Team?                @relation(fields: [teamId], references: [id], onDelete: SetNull)
  members     AthleteGroupMember[]
  invites     TeamInvite[]

  @@index([coachId])
  @@index([teamId])
}

model AthleteGroupMember {
  id          String       @id @default(uuid())
  groupId     String
  athleteId   String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  athlete     User         @relation("AthleteGroupMemberships", fields: [athleteId], references: [id], onDelete: Cascade)
  group       AthleteGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([groupId, athleteId])
  @@index([groupId])
  @@index([athleteId])
}

model TeamInvite {
  id        String   @id @default(uuid())
  teamId    String
  email     String?  // Optional: restrict to a specific email
  role      TeamRole @default(ATHLETE)
  code      String   @unique
  status    String   @default("PENDING") // PENDING, ACCEPTED, EXPIRED, REVOKED
  expiresAt DateTime
  groupId   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  group     AthleteGroup? @relation(fields: [groupId], references: [id], onDelete: SetNull)

  @@index([teamId])
  @@index([code])
}

model CustomFieldDefinition {
  id          String   @id @default(uuid())
  ownerId     String   // The User who defined this field
  entityType  String   // "WELLNESS" | "WORKOUT"
  fieldKey    String   // The key in the JSONB object
  label       String   // Display name
  dataType    String   // "NUMBER" | "BOOLEAN" | "STRING"
  unit        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  owner       User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([ownerId])
  @@unique([ownerId, entityType, fieldKey])
}

model Dashboard {
  id        String   @id @default(uuid())
  ownerId   String
  name      String
  layout    Json     // [{ widgetId: string, x: number, y: number, w: number, h: number }]
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  owner     User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  widgets   Widget[]

  @@index([ownerId])
  @@index([ownerId, order])
}

model Widget {
  id          String    @id @default(uuid())
  ownerId     String
  dashboardId String?
  name        String
  config      Json      // The AQL configuration
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  owner       User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  dashboard   Dashboard? @relation(fields: [dashboardId], references: [id], onDelete: SetNull)

  @@index([ownerId])
  @@index([dashboardId])
}

model TrainingPlanFolder {
  id          String   @id @default(uuid())
  userId      String
  parentId    String?
  name        String
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent      TrainingPlanFolder?   @relation("TrainingPlanFolderHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children    TrainingPlanFolder[]  @relation("TrainingPlanFolderHierarchy")
  plans       TrainingPlan[]

  @@index([userId])
  @@index([parentId])
}

model FavoriteTrainingPlan {
  id        String   @id @default(uuid())
  userId    String
  planId    String
  createdAt DateTime @default(now())

  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan TrainingPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([userId, planId])
  @@index([userId])
  @@index([planId])
}
