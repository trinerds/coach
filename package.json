  "name": "coach",
  "engines": {
    "node": ">=24.11.0 <25.0.0"
  },
  "private": true,
  "scripts": {
    "backfill-scores": "tsx scripts/backfill-scores.ts",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "build": "prisma generate && nuxt build",
    "dev": "NODE_OPTIONS='--max-old-space-size=12288' nuxt dev",
    "dev:trigger": "pnpm prisma:generate && npx trigger.dev@latest dev",
    "generate": "nuxt generate",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "postinstall": "prisma generate",
    "preview": "nuxt preview",
    "prisma:generate": "prisma generate",
    "release": "release-it",
    "release:patch": "release-it patch",
    "release:minor": "release-it minor",
    "release:major": "release-it major",
    "cli": "tsx ./cli/index.ts",
    "cw:cli": "tsx cli/index.ts",
    "cw:cli:chatroom": "tsx cli/index.ts debug chatroom",
    "cw:cli:nutrition:day-log": "tsx cli/index.ts nutrition day-log",
    "cw:cli:nutrition:review-glycogen": "tsx cli/index.ts nutrition review-glycogen",
    "cw:cli:nutrition:debug": "tsx cli/index.ts nutrition debug-metabolic",
    "cw:cli:nutrition:metabolic": "tsx cli/index.ts nutrition metabolic",
    "cw:cli:fueling:debug": "tsx cli/index.ts nutrition chain",
    "cw:cli:fueling:workout": "tsx cli/index.ts nutrition fueling-workout",
    "cw:cli:fueling:compare": "tsx cli/index.ts nutrition compare-fueling",
    "cw:worker": "tsx cli/worker/index.ts",
    "db:deploy": "prisma migrate deploy",
    "db:dump": "scripts/dump-db.sh",
    "db:dump:prod": "scripts/dump-db.sh DATABASE_URL_PROD",
    "prepare": "husky || true",
    "i18n:pull": "node -e \"require('dotenv').config(); require('child_process').spawn('tolgee', ['pull', '--api-url', process.env.TOLGEE_API_URL], { stdio: 'inherit', shell: true })\"",
    "i18n:push": "node -e \"require('dotenv').config(); require('child_process').spawn('tolgee', ['push', '--api-url', process.env.TOLGEE_API_URL], { stdio: 'inherit', shell: true })\""
