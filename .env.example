DATABASE_URL="postgresql://username:password@localhost:5439/dbname?connection_limit=20&pool_timeout=10&connect_timeout=10"
# E2E tests use a dedicated stack (Postgres + Redis + app) — see .env.e2e.example, docs/04-guides/e2e-testing.md, and `pnpm e2e:setup`
DATABASE_URL_PROD="postgresql://username:password@localhost:5439/dbname"

# PostgreSQL Connection (for scripts/tools)
POSTGRES_HOST=localhost
POSTGRES_PORT=5439
POSTGRES_DATABASE=coach
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password

# Google oauth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Sign in with Apple (web Services ID for Auth.js — App Store Guideline 4.8)
# Callback: {NUXT_AUTH_ORIGIN}/callback/apple  e.g. https://coachwatts.com/api/auth/callback/apple
# APPLE_ID = Services ID (e.g. com.coachwatts.web)
# Prefer key material (secret JWT is generated at runtime) OR set APPLE_CLIENT_SECRET directly.
# APPLE_ID=com.coachwatts.web
# APPLE_TEAM_ID=42K8S6866N
# APPLE_KEY_ID=your-key-id
# APPLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# APPLE_CLIENT_SECRET=   # optional pre-built JWT instead of APPLE_PRIVATE_KEY
# NUXT_PUBLIC_APPLE_SIGN_IN_ENABLED=true  # optional force-enable UI without detecting secrets

# Google Cloud Storage
# For development, you can place 'gcs-key.json' in the root (ignored by git).
# For production, set GCS_KEY_JSON with the content of the key file (JSON string).
# GCS_KEY_JSON='{"type": "service_account", ...}'
# GCLOUD_PROJECT=coach-app-481412
# GCS_BUCKET_NAME=coach-wattz-public-assets

# Gemini API KEY
GEMINI_API_KEY=your-gemini-api-key

# Trigger.dev
TRIGGER_SECRET_KEY=tr_dev_your-secret-key
TRIGGER_PROJECT_REF=proj_your-project-ref
TRIGGER_API_KEY=tr_dev_your-api-key

# Nuxt Auth Config
NUXT_AUTH_SECRET="your-auth-secret"
# IMPORTANT: This must be set at runtime for proper OAuth redirects
# The callback URL will be: {NUXT_AUTH_ORIGIN}/callback/google
# Development: NUXT_AUTH_ORIGIN="http://localhost:3099/api/auth"
# Production: NUXT_AUTH_ORIGIN="https://your-domain.com/api/auth"
NUXT_AUTH_ORIGIN="http://localhost:3099/api/auth"
NUXT_PUBLIC_SITE_URL="http://localhost:3099/"

STRAVA_CLIENT_ID="your-strava-client-id"
STRAVA_CLIENT_SECRET="your-strava-client-secret"
STRAVA_WEBHOOK_VERIFY_TOKEN="your-strava-webhook-verify-token"
NUXT_PUBLIC_STRAVA_ENABLED=true

WHOOP_CLIENT_ID="your-whoop-client-id"
WHOOP_CLIENT_SECRET="your-whoop-client-secret"

INTERVALS_CLIENT_ID="your-intervals-client-id"
INTERVALS_CLIENT_SECRET="your-intervals-client-secret"
INTERVALS_WEBHOOK_SECRET="your-intervals-webhook-secret"

WITHINGS_CLIENT_ID=""
WITHINGS_CLIENT_SECRET=""

FITBIT_CLIENT_ID=""
FITBIT_CLIENT_SECRET=""
FITBIT_SUBSCRIBER_VERIFICATION_CODE="your-verification-code"
FITBIT_ENABLE_INTRADAY_HEART_RATE="false"
# Set to "true" to enable intraday heart-rate fetches (may increase Fitbit API usage and rate limiting)

# Redis / DragonflyDB
REDIS_URL=redis://:dragonfly@localhost:6379
REALTIME_DEBUG=false
# Optional comma-separated filter for realtime log channels: activity,task_run,notification,chat,bus,ws
REALTIME_DEBUG_CHANNELS=
REALTIME_DEBUG_VERBOSE=false

# Worker Configuration
CW_WORKER_QUEUE_WEBHOOK_CONCURRENCY=5

# Sentry (disabled in local dev by default — set SENTRY_ENABLED=true to opt in)
# SENTRY_ENABLED=true
SENTRY_DSN="https://27c2bc691e512298040726bf5de7608a@o4508727277256704.ingest.de.sentry.io/4510667866243152"
SENTRY_AUTH_TOKEN="your-sentry-auth-token"
SENTRY_ORG="your-sentry-org"
SENTRY_PROJECT="your-sentry-project"

# Postmark Email API
POSTMARK_API_KEY="your-postmark-api-key"

# Rate Limiting
WEBHOOK_RATE_LIMIT_MAX=100
WEBHOOK_RATE_LIMIT_TTL=60

# Remote MCP server (https://app.coachwatts.com/mcp) — enabled by default; set false to disable
# NUXT_MCP_ENABLED=false
NUXT_MCP_READ_ENABLED=true
# NUXT_MCP_WRITE_ENABLED=false
# NUXT_MCP_ASYNC_ENABLED=false
NUXT_MCP_EXECUTION_ENABLED=true
NUXT_MCP_CLIENT_ALLOWLIST=
# Pre-registered Cursor MCP OAuth client ID (from: pnpm cw:cli oauth create-cursor-mcp-app ...)
COACH_WATTS_MCP_CLIENT_ID=
# NUXT_MCP_DCR_ENABLED=false
# Optional DCR owner override (defaults to first admin user when unset)
# NUXT_MCP_DCR_OWNER_USER_ID=
# NUXT_MCP_DCR_OWNER_EMAIL=
NUXT_MCP_DCR_RATE_LIMIT_PER_HOUR=10

